# Backend Environment Variables

# Server Configuration
PORT=5000
NODE_ENV=development

# Groq API Key (for AI content generation)
GROQ_API_KEY=your_groq_api_key_here

# MongoDB (Optional - for cloud version)
MONGODB_URI=mongodb://localhost:27017/squarepulse

# Email Configuration (for notifications)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# **IMPORTANT: Binance Spot Trading API Keys**
# These are server-side keys for bot trading and portfolio tracking
# Get from: https://www.binance.com/en/user/settings/api-management
# Create separate API key with restrictions:
# - Enable Spot Trading
# - Restrict to your IP (production)
BINANCE_API_KEY=your_binance_spot_api_key_here
BINANCE_SECRET_KEY=your_binance_spot_secret_key_here

# Encryption Key (for storing user API keys securely - min 32 chars)
ENCRYPTION_KEY=your_32_char_or_longer_encryption_key_here

# CoinGecko API (free tier works fine)
COINGECKO_API_KEY=optional_coingecko_api_key

# Whale Alert API (for whale tracking)
WHALE_ALERT_API_KEY=your_whale_alert_key_here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_PATH=./posts.db

# NOTE: Binance Square API Key is provided by EACH USER in the browser
# The BINANCE_API_KEY and BINANCE_SECRET_KEY above are for bot trading


