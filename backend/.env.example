# ============================================================
# SquarePulse + OpenClaw Environment Configuration (.env)
# ============================================================
# 
# IMPORTANT: This file is in .gitignore - never commit secrets!
# Copy this to .env and fill with your actual values.
#
# QUICK START:
# 1. Replace placeholders with your API keys
# 2. Generate ENCRYPTION_KEY: openssl rand -base64 32 (Mac/Linux)
#    or: [System.Guid]::NewGuid().ToString() (Windows PowerShell)
# 3. Save file and restart backend

# ========== SERVER SETTINGS ==========
PORT=5000
NODE_ENV=development
BACKEND_URL=http://localhost:5000

# ========== DATABASE ==========
DATABASE_FILE=posts.db

# ========== ENCRYPTION ==========
# CRITICAL: Generate a strong 32-character key
# Do NOT use the default value below - generate your own!
# 
# Windows PowerShell:
#   [System.Guid]::NewGuid().ToString().Replace("-","").Substring(0,32)
# 
# Mac/Linux:
#   openssl rand -base64 32
#
ENCRYPTION_KEY=your-32-char-encryption-key-here

# ========== EMAIL NOTIFICATIONS ==========
# Gmail SMTP Configuration
# REQUIRED: Use App Password, NOT your regular Gmail password!
# 
# Steps to create App Password:
# 1. Go to: https://myaccount.google.com/apppasswords
# 2. Select "Mail" and "Windows Computer"
# 3. Generate and copy the 16-character password
# 4. Paste below
#
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-16-char-app-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ========== AI MODEL SELECTION ==========
# Choose ONE primary model provider (try free tier first!)
# 
# Option 1: OpenAI (Paid, most reliable)
# Cost: ~$0.02-0.05 per trade
# Get key: https://platform.openai.com/api-keys
# Model: gpt-4-turbo
OPENAI_API_KEY=sk-...your-api-key-here...

# Option 2: Groq (FREE tier, very fast!)
# Cost: FREE for up to 30 requests/minute
# Get key: https://console.groq.com
# Recommended for testing
GROQ_API_KEY=gsk_...your-api-key-here...

# Option 3: Google Gemini (FREE tier)
# Cost: FREE for up to 60 requests/minute  
# Get key: https://ai.google.dev
GEMINI_API_KEY=your-api-key-here

# Which model to use by default
PRIMARY_AI_MODEL=groq

# ========== OPENCLAW CONFIGURATION ==========
# OpenClaw gateway settings
# 
# IMPORTANT: Change AUTH_TOKEN to random 32-char value!
# Windows PowerShell: -join ((33..126) | Get-Random -Count 32 | % {[char]$_})
# Mac/Linux: openssl rand -base64 32
#
OPENCLAW_AUTH_TOKEN=your-secure-32-char-random-token-here
OPENCLAW_BACKEND_URL=http://localhost:5000
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_GATEWAY_HOST=localhost
OPENCLAW_SECURE=false

# ========== OPTIONAL: TELEGRAM BOT ==========
# For mobile access via Telegram
# Steps:
# 1. Message @BotFather on Telegram
# 2. Create bot, get token
# 3. Message @getidsbot to get your chat ID
#
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# ========== OPTIONAL: SLACK BOT ==========
# For team collaboration
# Get from: https://api.slack.com/apps
#
SLACK_BOT_TOKEN=xoxb-...your-token...
SLACK_APP_TOKEN=xapp-...your-token...

# ========== OPTIONAL: WHATSAPP BOT ==========
# Requires Twilio account
# Get from: https://www.twilio.com
#
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ========== BINANCE INTEGRATION (OPTIONAL) ==========
# For automated posting to Binance Square
# Get from: https://www.binance.com/en/user/settings/api-management
# 
# ** IMPORTANT SECURITY **
# Create a dedicated API key with:
# - Enable only "Spot Trading" permission
# - Restrict to your IP address
# - No withdraw/transfer permissions
#
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here
BINANCE_SANDBOX=false  # Set to true for testing

# ========== LOGGING & DEBUGGING ==========
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE=logs/openclaw.log
DEBUG=false

# ========== MONITORING INTERVALS (milliseconds) ==========
# How often to check prices and positions
PRICE_CHECK_INTERVAL=900000    # 15 minutes
POSITION_UPDATE_INTERVAL=300000 # 5 minutes  
ALERT_CHECK_INTERVAL=60000      # 1 minute

# ========== FEATURE FLAGS ==========
# Enable/disable system features
ENABLE_AUTO_TRADING=true
ENABLE_EMAIL_ALERTS=true
ENABLE_PRICE_MONITORING=true
ENABLE_ADVANCED_ANALYTICS=true
ENABLE_DATABASE_BACKUP=true

# ========== SECURITY ==========
SESSION_TIMEOUT=3600000  # 1 hour
MAX_LOGIN_ATTEMPTS=5
ALLOW_CROSS_ORIGIN=true
CORS_ORIGINS=http://localhost:3000,http://localhost:5000,http://127.0.0.1:3000

# ========== DATABASE BACKUP ==========
# Automatic backups of trading history
BACKUP_ENABLED=true
BACKUP_INTERVAL=86400000  # 24 hours
BACKUP_LOCATION=./backups/
BACKUP_RETENTION_DAYS=90  # Keep 90 days of backups

# ========== MONGODB (OPTIONAL - for cloud deployment) ==========
# Leave empty if using SQLite (default)
# For cloud, use MongoDB Atlas: https://www.mongodb.com/cloud/atlas
MONGODB_URI=

# ========== PRODUCTION SETTINGS ==========
# Only change when deploying to production server/VPS
NODE_ENV=development  # Change to 'production' on live server
ALLOW_REMOTE_CONNECTIONS=false  # Set to true only if behind firewall
VPS_DOMAIN=your-domain.com  # Only if using custom domain

# ========== ADVANCED SETTINGS ==========
# Usually don't need to change these
API_TIMEOUT=5000  # API request timeout in ms
MAX_POSITIONS=100  # Max open positions to track
MAX_DAILY_TRADES=50  # Max trades per day per user (safety)
RATE_LIMIT=100  # API rate limit (requests/minute)

# ========== NOTES ==========
# - Keep this file PRIVATE - never share API keys!
# - .env is in .gitignore - it won't be committed to Git
# - For each AI provider, you only need ONE API key
# - Start with free tier (Groq) for testing
# - Email MUST be Gmail with App Password (2FA required)
# - Telegram/Slack are optional - add later if needed
# 
# Questions? See: SQUAREPULSE_OPENCLAW_SETUP.md

# CoinGecko API (free tier works fine)
COINGECKO_API_KEY=optional_coingecko_api_key

# Whale Alert API (for whale tracking)
WHALE_ALERT_API_KEY=your_whale_alert_key_here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_PATH=./posts.db

# NOTE: Binance Square API Key is provided by EACH USER in the browser
# The BINANCE_API_KEY and BINANCE_SECRET_KEY above are for bot trading


